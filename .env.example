# ============================================================
#  PostFlow — environment template
#  Copy to .env and fill in. Generate secrets with:
#    openssl rand -hex 32     # TOKEN_ENCRYPTION_KEY, CRON_SECRET
#    openssl rand -base64 32  # NEXTAUTH_SECRET
# ============================================================

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/postflow?schema=public"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# --- Token encryption (AES-256-GCM). 32-byte key as 64 hex chars ---
TOKEN_ENCRYPTION_KEY=""

# --- Cron / worker shared secret ---
CRON_SECRET=""

# --- Redis (BullMQ queue) ---
REDIS_URL="redis://127.0.0.1:6379"

# --- Google OAuth (login + YouTube Data API v3) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- TikTok Content Posting API ---
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# --- Meta / Instagram Graph API (Facebook Login) ---
META_APP_ID=""
META_APP_SECRET=""

# --- S3 / Cloudflare R2 (presigned uploads) ---
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="postflow-media"
S3_PUBLIC_URL=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- SMTP (email verification, notifications, support) ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="PostFlow <no-reply@postflow.app>"
SUPPORT_EMAIL="support@postflow.app"

# --- Resend (HTTP email — recommended on cloud hosts that block SMTP) ---
# If set, email is sent via Resend instead of SMTP. Get a key at resend.com.
RESEND_API_KEY=""

# --- Upstash (optional rate limiting; empty => fallback to Redis/in-memory) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
