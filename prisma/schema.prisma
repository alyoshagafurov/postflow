// PostFlow — Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  Enums
// ============================================================

enum Role {
  USER
  ADMIN
}

enum Platform {
  YOUTUBE
  TIKTOK
  INSTAGRAM
}

enum SocialAccountStatus {
  ACTIVE
  EXPIRED
  REVOKED
  PENDING_VERIFICATION // TikTok/IG account awaiting platform app review
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  PARTIALLY_PUBLISHED
  FAILED
}

enum PublicationStatus {
  PENDING
  QUEUED
  PROCESSING
  PUBLISHED
  FAILED
  CANCELED
}

enum PlanTier {
  FREE
  STARTER
  PRO
  UNLIMITED
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
}

enum PromoType {
  PERCENT
  AMOUNT
  UNLIMITED
}

enum LimitBehavior {
  QUEUE_NEXT_DAY
  SUGGEST_UPGRADE
}

enum NotificationType {
  PUBLISH_SUCCESS
  PUBLISH_FAILED
  TOKEN_EXPIRED
  ACCOUNT_CONNECTED
  SYSTEM
}

// ============================================================
//  Auth (NextAuth) + User
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)

  timezone String @default("UTC")
  locale   String @default("ru")

  // Optional email-code 2FA
  twoFactorEnabled Boolean   @default(false)
  twoFactorCode    String?
  twoFactorExpires DateTime?

  // When the daily limit is exceeded
  limitBehavior LimitBehavior @default(SUGGEST_UPGRADE)

  onboardedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts         Account[]
  sessions         Session[]
  socialAccounts   SocialAccount[]
  posts            Post[]
  publications     Publication[]
  subscription     Subscription?
  promoRedemptions PromoRedemption[]
  auditLogs        AuditLog[]
  usageCounters    UsageCounter[]
  notifications    Notification[]

  @@index([email])
}

// NextAuth OAuth accounts (e.g. Google login)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ============================================================
//  Social accounts (encrypted tokens)
// ============================================================

model SocialAccount {
  id       String   @id @default(cuid())
  userId   String
  platform Platform

  platformAccountId String // channel id / open id / ig user id
  username          String?
  displayName       String?
  avatarUrl         String?

  // AES-256-GCM encrypted; never store plaintext tokens
  accessTokenEnc  String  @db.Text
  refreshTokenEnc String? @db.Text
  tokenExpiresAt  DateTime?
  scope           String? @db.Text

  status    SocialAccountStatus @default(ACTIVE)
  lastError String?             @db.Text

  // platform extras (IG business id, FB page id, YT channel meta, etc.)
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  postTargets  PostTarget[]
  publications Publication[]

  @@unique([userId, platform, platformAccountId])
  @@index([userId])
  @@index([status])
}

// ============================================================
//  Posts / targets / publications
// ============================================================

model Post {
  id     String @id @default(cuid())
  userId String

  // shared content
  title       String?
  description String? @db.Text
  hashtags    String? @db.Text

  // media
  videoKey         String? // S3 object key
  videoUrl         String?
  videoSizeBytes   BigInt?
  videoDurationSec Int?
  videoMime        String?
  videoWidth       Int?
  videoHeight      Int?

  coverKey String? // chosen cover S3 key
  coverUrl String?

  perPlatformText Boolean @default(false)

  status PostStatus @default(DRAFT)

  // scheduling stored in UTC; timezone captured for display/limit accounting
  scheduledAt DateTime?
  timezone    String?
  publishNow  Boolean   @default(false)

  // explicit consent (TikTok/Meta review requirement)
  consentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  targets      PostTarget[]
  publications Publication[]
  coverOptions CoverOption[]

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}

model CoverOption {
  id           String   @id @default(cuid())
  postId       String
  key          String // S3 key
  url          String?
  timestampSec Float?
  isCustom     Boolean  @default(false)
  createdAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostTarget {
  id              String @id @default(cuid())
  postId          String
  socialAccountId String

  // per-platform overrides (used when Post.perPlatformText = true)
  title    String?
  caption  String? @db.Text
  hashtags String? @db.Text

  // platform options: privacy, comments, etc.
  privacy String?
  options Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  publication   Publication?

  @@unique([postId, socialAccountId])
  @@index([postId])
  @@index([socialAccountId])
}

model Publication {
  id              String   @id @default(cuid())
  postId          String
  postTargetId    String   @unique
  socialAccountId String
  userId          String
  platform        Platform

  status      PublicationStatus @default(PENDING)
  scheduledAt DateTime? // UTC
  startedAt   DateTime?
  publishedAt DateTime?

  // platform result
  platformPostId String? // youtube video id / tiktok publish id / ig media id
  platformUrl    String?
  errorCode      String?
  errorMessage   String? @db.Text
  attempts       Int     @default(0)

  jobId             String? // BullMQ job id
  countsAgainstDate DateTime? @db.Date // user-local calendar date used for limit accounting

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postTarget    PostTarget    @relation(fields: [postTargetId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
  @@index([platform])
}

// ============================================================
//  Billing: plans / subscriptions / promo codes
// ============================================================

model Plan {
  id          String   @id @default(cuid())
  tier        PlanTier @unique
  name        String
  description String?

  dailyLimit    Int? // null = unlimited
  minDailyLimit Int? // configurable range (Pro)
  maxDailyLimit Int?

  priceCents      Int     @default(0)
  currency        String  @default("usd")
  stripePriceId   String?
  stripeProductId String?

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)
  features  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id     String @id @default(cuid())
  userId String @unique
  planId String

  tier   PlanTier           @default(FREE)
  status SubscriptionStatus @default(ACTIVE)

  // configurable Pro limit within plan min/max
  customDailyLimit  Int?
  // hard unlimited override (e.g. lifetime promo)
  unlimitedOverride Boolean @default(false)

  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)

  appliedPromoId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan       @relation(fields: [planId], references: [id])
  appliedPromo PromoCode? @relation(fields: [appliedPromoId], references: [id])

  @@index([userId])
  @@index([stripeCustomerId])
}

model PromoCode {
  id          String    @id @default(cuid())
  code        String    @unique
  description String?
  type        PromoType @default(PERCENT)

  percentOff      Int? // 0..100
  amountOffCents  Int?
  grantsUnlimited Boolean   @default(false)
  grantsTier      PlanTier?
  durationMonths  Int? // null = forever

  stripeCouponId        String?
  stripePromotionCodeId String?

  isActive        Boolean   @default(true)
  maxRedemptions  Int? // null = unlimited
  redemptionCount Int       @default(0)
  expiresAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions   PromoRedemption[]
  subscriptions Subscription[]
}

model PromoRedemption {
  id      String @id @default(cuid())
  promoId String
  userId  String

  createdAt DateTime @default(now())

  promo PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoId, userId])
  @@index([userId])
}

// ============================================================
//  Usage accounting / audit / notifications
// ============================================================

model UsageCounter {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date // user-local calendar date
  count  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String? // actor (null for system)
  action     String // e.g. "social_account.connect", "publication.publish"
  targetType String?
  targetId   String?
  platform   Platform?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Notification {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  title  String
  body   String?          @db.Text
  link   String?
  readAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}
